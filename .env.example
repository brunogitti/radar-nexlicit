# Copie este arquivo para ".env" (sem o ".example") e preencha com os
# valores reais. O ".env" de verdade nunca vai pro Git (esta no
# .gitignore); este arquivo de exemplo vai, porque nao tem segredo nenhum
# dentro, so os nomes das variaveis.

# O e-mail do Gmail que envia (aparece como remetente).
GMAIL_USER=

# Senha de APP do Google, nao a senha normal da conta.
# Gerar em: https://myaccount.google.com/apppasswords
# (precisa ter verificacao em duas etapas ativada na conta pra essa opcao aparecer)
GMAIL_APP_PASSWORD=
